// Prisma schema for צדקת רבותינו ordering system
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

// לקוחות קצה - הרשמה עצמאית, התחברות עם טלפון או מייל (חובה לפחות אחד)
model Customer {
  id                   String    @id @default(cuid())
  name                 String
  // אחד מהשניים (phone/email) חייב להיות מלא - נאכף בקוד (Prisma לא תומך
  // ב"אחד משני שדות חובה" ברמת הסכמה). שניהם unique כדי למנוע כפילות חשבון.
  phone                String?   @unique
  email                String?   @unique
  passwordHash         String
  role                 String    @default("CUSTOMER") // CUSTOMER / AGENT / ADMIN
  // נקודת חלוקה ברירת מחדל - נבחרת חובה בהרשמה, ניתנת לשינוי באזור האישי
  defaultPointId       String?
  defaultPoint         DeliveryPoint? @relation(fields: [defaultPointId], references: [id])
  resetToken           String?   @unique
  resetTokenExpiry     DateTime?
  // תשלום ואימות כרטיס - הטוקן מגיע מ-webhook של נדרים אחרי חיוב אימות 1₪ בהרשמה
  paymentToken         String?
  cardLast4            String?
  cardVerifiedAt       DateTime?
  creditVerificationCharged Boolean @default(false)
  // תוקף כרטיס (MM/YY או YYMM כפי שנדרים מחזירים) - נשמר מ-webhook להצגה במסך המנהל
  cardExpiry           String?
  // הפך ל-true כשניסיון חיוב אחרון נכשל בגלל טוקן פסול/כרטיס פג-תוקף.
  // מתאפס ל-false כשנשמר טוקן חדש (webhook רישום חוזר).
  cardNeedsUpdate      Boolean   @default(false)
  // שדות נציג (רלוונטיים רק כאשר role=AGENT)
  // agentPointId: הנקודה שהנציג מוגבל אליה. null = רואה את כל הלקוחות
  agentPointId         String?
  agentPoint           DeliveryPoint? @relation("AgentPoint", fields: [agentPointId], references: [id])
  // הרשאות נציג נפרדות: קביעת מחיר סופי / שליחת לינק תשלום
  agentCanSetFinalPrice Boolean @default(false)
  agentCanSendPaymentLink Boolean @default(false)
  // עמלת נציג לפי ק"ג - קרטונים ובודדים בנפרד
  // ברירת מחדל: 1 ש"ח לק"ג לקרטונים, 4 ש"ח לק"ג לבודדים (1 בסיסי + 3 תוספת)
  commissionRateCarton  Decimal @default(1) @db.Decimal(10, 2)
  commissionRateSingles Decimal @default(4) @db.Decimal(10, 2)
  orders               Order[]
  personalRequests     PersonalRequest[]
  // §20: מכירות ותשלומים של הנציג
  agentSaleSummaries   AgentSaleSummary[]
  agentPayments        AgentPayment[]
  walkinOrders         WalkinOrder[] @relation("WalkinAgent")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            String   @id @default(cuid())
  name          String
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  // מחיר קרטון הוא ברירת המחדל המוצגת מהמחירון
  cartonPrice   Decimal  @db.Decimal(10, 2)
  // האם המוצר תומך בקנייה בבודדים (בשר/דגים) עם תוספת לק"ג
  allowSingles  Boolean  @default(false)
  // תוספת מחיר לבודדים לק"ג (ברירת מחדל 3 ש"ח, ניתן לעריכה גלובלית/למוצר)
  singleSurcharge Decimal? @db.Decimal(10, 2)
  // מצב בודדים: KG = לפי ק"ג (בשר, ברירת מחדל) / UNITS = לפי יחידות (סלומון וכד')
  singlesMode      String   @default("KG")
  // מחיר קבוע ליחידה בבודדים - נדרש כאשר singlesMode="UNITS"
  singleUnitPrice  Decimal? @db.Decimal(10, 2)
  unit          String   @default("ק\"ג") // ק"ג / יחידה / מארז
  saleType      String   @default("WEIGHT") // WEIGHT / UNIT / PACKAGE
  // סוג המחיר: REGULAR (מחיר רגיל לק"ג/יחידה/מארז) / CARTON (מחיר קרטון, בודדים בתוספת)
  priceType     String   @default("REGULAR") // REGULAR / CARTON
  packageWeight String?  // 200 גרם / 400 גרם / 500 גרם / 900 גרם
  // משקל ממוצע משוער ליחידה/קרטון - משמש לחישוב מחיר משוער מדויק יותר ללקוח
  avgWeightPerUnit Decimal? @db.Decimal(10, 3)
  imageUrl      String?  // תמונת המוצר (Supabase Storage)
  kashrut       String?  // כשרות: לנדא / אגודת ישראל / בד"ץ העדה החרדית...
  isFeatured    Boolean  @default(false) // מוצר מבצע - מודגש ללקוח
  highlightNote String?  // הערת הדגשה ("בקרטונים בלבד - לא בבודדים")
  isFrozen      Boolean  @default(false)
  limitedQty    Boolean  @default(false)
  limitedQtyAmount Int?   // מגבלת כמות שהמנהל מגדיר (תצוגה/אזהרה בלבד, לא חוסם לקוח)
  // §9: האם המוצר זמין להזמנה אישית (מלבד מכירות רגילות)
  allowPersonalOrder Boolean @default(true)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  orderItems    OrderItem[]
  pricelists    PricelistProduct[]
  // §20: מודול נציגים
  deliveryNoteItems DeliveryNoteItem[]
  walkinOrderItems  WalkinOrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeliveryPoint {
  id           String   @id @default(cuid())
  name         String
  city         String?
  address      String?
  contactName  String?
  phone        String?
  email        String?
  deliveryHours String?
  // §6: תאריך חלוקה חריג לנקודה זו (עדיף על deliveryDateText של המחירון)
  // אם null - משתמשים בתאריך של המחירון. אם קיים - הנקודה מקבלת בתאריך שונה.
  // שימושי לחגים, לנקודות עם מועד קבלה שונה, וכד'.
  customDeliveryDateText String?
  notes        String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  orders       Order[]
  pricelists   PricelistPoint[]
  customers    Customer[] // לקוחות שבחרו נקודה זו כברירת מחדל
  agents       Customer[] @relation("AgentPoint") // נציגים המוגבלים לנקודה זו
  personalProducts PersonalProduct[] @relation("PersonalProductPoint") // §9: מוצרים אישיים בנקודה זו
  createdAt    DateTime @default(now())
}

model Pricelist {
  id            String   @id @default(cuid())
  name          String
  openDate      DateTime?
  closeDate     DateTime?
  // §16: עד מתי לקוח יכול לערוך/לבטל הזמנה קיימת (אם null - fallback ל-closeDate)
  editDeadline  DateTime?
  deliveryDate  DateTime?
  // §6/#6: תאריך חלוקה סוף — אם חלוקה מתפרסת על מספר ימים
  deliveryDateEnd DateTime?
  deliveryDateText String?  // טקסט חופשי לתאריך עברי
  notes         String?
  status        String   @default("DRAFT") // DRAFT / ACTIVE / CLOSED / DONE
  singleSurcharge Decimal @default(3) @db.Decimal(10, 2) // תוספת לבודדים גלובלית למחירון
  points        PricelistPoint[]
  products      PricelistProduct[]
  orders        Order[]
  // §20: מודול נציגים
  agentSaleSummaries AgentSaleSummary[]
  deliveryNotes     DeliveryNote[]
  walkinOrders      WalkinOrder[]
  agentPayments     AgentPayment[]
  createdAt     DateTime @default(now())
}

model PricelistPoint {
  id            String   @id @default(cuid())
  pricelistId   String
  pricelist     Pricelist @relation(fields: [pricelistId], references: [id], onDelete: Cascade)
  pointId       String
  point         DeliveryPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)
  @@unique([pricelistId, pointId])
}

model PricelistProduct {
  id          String   @id @default(cuid())
  pricelistId String
  pricelist   Pricelist @relation(fields: [pricelistId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  // מחיר ספציפי למחירון (אם null נופל חזרה למחיר המוצר)
  price       Decimal?  @db.Decimal(10, 2)
  @@unique([pricelistId, productId])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     Int      @unique @default(autoincrement())
  pricelistId     String?
  pricelist       Pricelist? @relation(fields: [pricelistId], references: [id])
  pointId         String
  point           DeliveryPoint @relation(fields: [pointId], references: [id])
  // כל הזמנה משויכת ללקוח רשום (אין יותר הזמנת אורח)
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  // snapshot של מה שהלקוח ראה/הזין בזמן ההזמנה (לתיעוד - לא משתנה גם אם הלקוח עצמו ישתנה אחר כך)
  pointNameSnapshot     String?
  deliveryDateSnapshot  String?
  pricelistNameSnapshot String?
  customerName    String
  phone           String
  phone2          String?
  notes           String?
  internalNotes   String?

  // מחזור חיים: PENDING_REVIEW -> FINAL_PRICE_SET -> PAYMENT_PENDING -> PAID -> READY_FOR_PICKUP -> COMPLETED
  // (או CANCELLED בכל שלב)
  status          String   @default("PENDING_REVIEW")

  estimatedTotal  Decimal  @db.Decimal(10, 2) // מחיר משוער בזמן ההזמנה
  // §13: מספר תשלומים שהלקוח ביקש (1 = רגיל, 2 = שני תשלומים מעל 800₪)
  requestedInstallments Int @default(1)
  finalTotal      Decimal? @db.Decimal(10, 2) // מחיר סופי אחרי שקילה ע"י נציג/מנהל

  // תשלום - משתנים אך ורק מהשרת (admin API מאומת עם תפקיד מורשה, או webhook חתום מהסולק). אף פעם לא מהדפדפן.
  // PENDING (טרם נקבע מחיר סופי) / PAYMENT_PENDING (ממתין לתשלום אונליין) / PAID / PARTIALLY_PAID / FAILED / REFUNDED
  paymentStatus       String    @default("PENDING")
  // ONLINE (אונליין דרך נדרים) / CASH (מזומן בשטח) / BANK_TRANSFER / MANUAL
  paymentMethod        String?
  paymentLink          String?
  amountPaid            Decimal?  @db.Decimal(10, 2) // מה שבפועל שולם (יכול להיות שונה מ-finalTotal)
  paidAt                DateTime?
  paymentTransactionId String?
  paymentProvider      String?   // למשל "nedarim_plus"
  // מודול חיוב אוטומטי (§19) - מעקב אחרי ניסיונות חיוב עם הטוקן השמור של הלקוח
  chargeAttempts       Int       @default(0)
  lastChargeError      String?
  lastChargeAt         DateTime?
  // תשלום מזומן - תיעוד חובה
  receivedByUserId     String?   // מזהה/מייל המנהל-נציג שקיבל את הכסף בפועל
  manualPaymentNote    String?

  // מתי אישרו אדמין/נציג מחיר סופי, ומי
  finalPriceSetAt DateTime?
  finalPriceSetBy String?
  // אם ההזמנה בוצעה ע"י נציג בשם הלקוח - מזהה הנציג
  placedByAgentId String?   // email של המנהל/נציג שעדכן

  // מעקב אישורים שנשלחו (לא מפיל את ההזמנה אם נכשל - רק לוג)
  adminNotifiedAt    DateTime?
  adminNotifyError   String?
  customerNotifiedAt DateTime?
  customerNotifyError String?

  items           OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  productName   String   // snapshot
  unit          String
  isSingle      Boolean  @default(false) // נקנה בבודדים (תוספת)
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(10, 2) // מחיר ליחידה ששמור בהזמנה (snapshot)
  estimatedWeight Decimal? @db.Decimal(10, 3) // משקל משוער (לפי avgWeightPerUnit של המוצר, אם קיים)
  estimatedPrice Decimal @db.Decimal(10, 2)
  actualWeight  Decimal? @db.Decimal(10, 3) // משקל בפועל - מעודכן ע"י נציג/מנהל אחרי שקילה
  finalWeight   Decimal? @db.Decimal(10, 3) // נשמר לתאימות לאחור (זהה ל-actualWeight)
  finalPrice    Decimal? @db.Decimal(10, 2)
  // §20: שדות של נציג - נעולים לחישוב עמלה (המנהל יכול לתקן finalWeight, אבל agentEnteredWeight נשמר)
  agentEnteredWeight Decimal? @db.Decimal(10, 3) // המשקל שהנציג הזין - נעול לעמלה
  agentEnteredById   String?  // מזהה הנציג שהזין (Customer.id)
  agentNote          String?  // הערה חופשית מהנציג ("הגיע צלעות במקום כתפיים")
  isCancelled        Boolean  @default(false) // לקוח לא רצה - לא מחייבים
  originalProductId  String?  // מוצר מקורי לפני החלפה (לתיעוד)
}

// הגדרות מערכת גלובליות - שורה יחידה, נערכת מאזור הניהול
model SystemSettings {
  id                    String  @id @default("singleton")
  adminEmail            String  @default("m5402088@gmail.com")
  adminWhatsappPhone    String?
  sendEmailToCustomer   Boolean @default(true)
  sendEmailToAdmin      Boolean @default(true)
  customerEmailTemplate String? // נוסח חופשי, null = ברירת המחדל הקבועה בקוד
  adminEmailTemplate    String?
  personalOrdersEnabled Boolean @default(false) // מתג מודול הזמנות אישיות
  updatedAt             DateTime @updatedAt
}

// תיעוד audit לכל סימון תשלום ידני (מזומן/העברה) - לא נמחק לעולם, רק נוסף
model PaymentAuditLog {
  id              String   @id @default(cuid())
  orderId         String
  action          String   // "MANUAL_CASH_PAYMENT" / "REFUND" / וכו'
  amountPaid      Decimal  @db.Decimal(10, 2)
  finalTotalAtTime Decimal @db.Decimal(10, 2) // מה היה finalTotal ברגע הסימון, לתיעוד
  paymentMethod   String   // CASH / BANK_TRANSFER / MANUAL
  receivedByUserId String  // מי ביצע את הפעולה (חובה - אין רישום אנונימי)
  note            String?
  createdAt       DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// מודול הזמנות אישיות - נפרד לחלוטין ממערכת המכירות
// ═══════════════════════════════════════════════════════════

// §9 מיושן: המודל הישן של מוצרים אישיים.
// היום מוצרי המחירון (Product) עם `allowPersonalOrder=true` משמשים גם להזמנות אישיות.
// הטבלה נשמרת כרגע ליישום המנהל, אבל לא בשימוש חדש.
model PersonalProduct {
  id          String   @id @default(cuid())
  name        String
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  maxQuantity Int?
  stock       Int?
  pointId     String?
  point       DeliveryPoint? @relation("PersonalProductPoint", fields: [pointId], references: [id])
  createdAt   DateTime @default(now())
}

// בקשת הזמנה אישית של לקוח
model PersonalRequest {
  id           String   @id @default(cuid())
  requestNumber Int     @unique @default(autoincrement())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  customerName String   // snapshot
  phone        String   // snapshot
  notes        String?
  status       String   @default("NEW") // NEW/IN_PROGRESS/CONTACTED/WAITING/DONE/CANCELLED
  // §9: מסמן שיש הודעה חדשה שלא נקראה (מנהל / לקוח)
  hasUnreadForAdmin    Boolean @default(true)
  hasUnreadForCustomer Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items        PersonalRequestItem[]
  messages     PersonalRequestMessage[]
}

model PersonalRequestItem {
  id         String          @id @default(cuid())
  requestId  String
  request    PersonalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  // §9: productId כמחרוזת ללא FK - יכול להצביע ל-Product רגיל.
  // אין FK כדי לאפשר migration בטוח מ-PersonalProduct הישן ל-Product החדש.
  // ה-productName נשמר כ-snapshot ומספיק לתצוגה.
  productId  String
  productName String
  quantity   Int
}

// §9: הודעות בין לקוח למנהל בבקשה אישית
model PersonalRequestMessage {
  id         String   @id @default(cuid())
  requestId  String
  request    PersonalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  senderType String   // "CUSTOMER" / "ADMIN"
  senderName String   // snapshot של שם השולח
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([requestId])
}

// ═══════════════════════════════════════════════════════════════
// §20: מודול נציגים - חלוקה, משקלים, עמלות, תעודות משלוח, מזדמנים
// ═══════════════════════════════════════════════════════════════

// סיכום עבודת נציג במכירה ספציפית - מחושב חי, נעול בסוף
model AgentSaleSummary {
  id                  String   @id @default(cuid())
  pricelistId         String
  pricelist           Pricelist @relation(fields: [pricelistId], references: [id], onDelete: Cascade)
  agentId             String
  agent               Customer  @relation(fields: [agentId], references: [id])
  // סיכומים - מחושבים ונשמרים בסגירת המכירה על ידי הנציג
  totalCartonWeight   Decimal   @default(0) @db.Decimal(10, 3) // ק"ג קרטונים ללקוחות
  totalSinglesWeight  Decimal   @default(0) @db.Decimal(10, 3) // ק"ג בודדים
  totalWalkinWeight   Decimal   @default(0) @db.Decimal(10, 3) // ק"ג מזדמנים
  totalCustomers      Int       @default(0) // מספר לקוחות שטופלו
  totalWalkins        Int       @default(0) // מספר מזדמנים
  cartonCommission    Decimal   @default(0) @db.Decimal(10, 2) // עמלה על קרטונים
  singlesCommission   Decimal   @default(0) @db.Decimal(10, 2) // עמלה על בודדים
  totalCommission     Decimal   @default(0) @db.Decimal(10, 2) // עמלה כוללת
  // "נותר/זרוק" - להסבר פערים מתעודת המשלוח
  remainderNote       String?   @db.Text
  // סטטוס: DRAFT (בעריכה) / CONFIRMED (נציג סגר את המכירה)
  status              String    @default("DRAFT")
  confirmedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([pricelistId, agentId])
  @@index([status])
}

// תעודת משלוח מהספק - מועלית ע"י המנהל, מאושרת ומשמשת מקור אמת לק"ג קרטונים
model DeliveryNote {
  id             String   @id @default(cuid())
  pricelistId    String
  pricelist      Pricelist @relation(fields: [pricelistId], references: [id])
  // תמונה מקורית שהמנהל צילם/העלה
  imageUrl       String?
  // נתונים גולמיים כפי שחזרו מ-Gemini (JSON)
  ocrRawData     String?  @db.Text
  // פרטים שחולצו לגבי התעודה עצמה
  supplierName   String?  // שם הספק (למשל "לנדה סחר")
  noteNumber     String?  // מספר תעודה
  noteDate       DateTime? // תאריך התעודה
  // סטטוס: DRAFT (רק חולץ ע"י OCR) / CONFIRMED (המנהל אישר) / REJECTED
  status         String   @default("DRAFT")
  confirmedById  String?  // מזהה מי אישר
  confirmedAt    DateTime?
  items          DeliveryNoteItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([pricelistId])
  @@index([status])
}

// שורת מוצר בתעודת משלוח - כל שורה = מוצר אחד עם קרטונים ומשקל
model DeliveryNoteItem {
  id              String       @id @default(cuid())
  deliveryNoteId  String
  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  // productId - שיוך למוצר במערכת. NULL אם עדיין לא הותאם
  productId       String?
  product         Product?     @relation(fields: [productId], references: [id])
  // השם כפי שהופיע בתעודה (לפני התאמה)
  productNameOnNote String
  quantity        Int          // מספר קרטונים
  weight          Decimal      @db.Decimal(10, 3) // סה"כ ק"ג לפי התעודה
  // אמון של Gemini - 0.0 עד 1.0. שורה עם confidence נמוך מסומנת אדום למנהל
  confidence      Decimal?     @db.Decimal(3, 2)
  // האם המנהל הוסיף את השורה ידנית (אחרי OCR)
  addedManually   Boolean      @default(false)
  // הערה חופשית (למשל: "שם לא ברור בתעודה")
  note            String?
  sortOrder       Int          @default(0)
}

// לקוח מזדמן - הגיע לחלוקה בלי הזמנה מוקדמת
model WalkinOrder {
  id              String   @id @default(cuid())
  walkinNumber    Int      @unique @default(autoincrement()) // מספר מזדמן רץ
  pricelistId     String
  pricelist       Pricelist @relation(fields: [pricelistId], references: [id])
  agentId         String
  agent           Customer  @relation("WalkinAgent", fields: [agentId], references: [id])
  // פרטי הלקוח - שם חובה, טלפון אופציונלי (אבל מומלץ ל-SMS)
  customerName    String
  customerPhone   String?
  // אמצעי תשלום
  paymentMethod   String   // CASH / CARD_TERMINAL / TRANSFER / ONLINE / CARD_ONLINE
  // האם התקבל בפועל - לתשלומים כמו העברה בנקאית שצריך לוודא
  paymentReceived Boolean  @default(true)  // ברירת מחדל true (מזומן / אשראי במסוף = מיד)
  // הערה על התשלום (למשל: "4 ספרות אחרונות: 4523, אישור: 123456")
  paymentNote     String?
  // סה"כ הזמנה
  totalAmount     Decimal  @default(0) @db.Decimal(10, 2)
  // הערות כלליות
  notes           String?
  items           WalkinOrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([pricelistId])
  @@index([agentId])
  @@index([paymentMethod, paymentReceived])
}

// פריט של הזמנת מזדמן
model WalkinOrderItem {
  id              String   @id @default(cuid())
  walkinOrderId   String
  walkinOrder     WalkinOrder @relation(fields: [walkinOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  productName     String   // snapshot
  weight          Decimal  @db.Decimal(10, 3) // ק"ג בפועל
  unitPrice       Decimal  @db.Decimal(10, 2) // מחיר ליחידה בזמן ההזמנה
  isSingle        Boolean  @default(false)   // בודדים
  totalPrice      Decimal  @db.Decimal(10, 2) // weight × unitPrice
  note            String?
}

// תשלום שהמנהל שילם לנציג - היסטוריה + מעקב חוב
model AgentPayment {
  id            String   @id @default(cuid())
  agentId       String
  agent         Customer @relation(fields: [agentId], references: [id])
  amount        Decimal  @db.Decimal(10, 2) // סכום ששולם (חיובי) או שנציג חייב (שלילי)
  // סוג: PAID (המנהל שילם לנציג) / COLLECTED (הנציג העביר מזומן שאסף)
  type          String
  // אמצעי תשלום
  method        String?  // BANK_TRANSFER / CASH / CHECK / OTHER
  note          String?  @db.Text // הערה חופשית ("מזומן שאסף בחלוקה של יום ראשון")
  // קישור למכירה ספציפית (אופציונלי - יכול להיות תשלום כללי)
  pricelistId   String?
  pricelist     Pricelist? @relation(fields: [pricelistId], references: [id])
  createdById   String?  // מזהה המנהל שרשם
  createdAt     DateTime @default(now())

  @@index([agentId])
  @@index([pricelistId])
}
